{% extends 'base_view.html.twig' %}

{% block plugins %}
    {{ parent() }}
    <script src="{{ asset("assets/unitarynote.js") }}"></script>
{% endblock %}

{% set youbis = ['月', '火', '水', '木', '金', '土', '日'] %}

{% block contents_wide %}
    <h2>{{ form_name }}</h2>
    <div class="mt-4 calender-box-header">
        <div style="display: flex; align-items: center; justify-content: center; gap: 12px;">
            <a class="btn btn-outline-primary btn-sm" href="{{ path('app_unitary_monthly', { tagName: thisTag.name ?? '', month: previous_month }) }}">
                << 
            </a>
            <div>{{ this_month | date('Y年m月') }}</div>
            <a class="btn btn-outline-primary btn-sm" href="{{ path('app_unitary_monthly', { tagName: thisTag.name ?? '', month: next_month }) }}">
                >>
            </a>
        </div>
    </div>
    <div style="display: flex; flex-wrap: wrap;">
        <div class="calender-cards-box">
        {% for youbi in youbis %}
            <div class="calender-card youbi">
                <span class="calender-youbi">{{ youbi }}</span>
            </div>
        {% endfor %}
        {% for calender_note in calender_notes %}
            <div class="calender-card">
                <div class="note-card" style="opacity: {{ calender_note.month != this_month ? '0.2' : '1' }};">
                    <div class="calender-title-row">
                        <a href="{{ path('new_unitary_with_compact', { date: calender_note.date.getDateString() }) }}" style="text-decoration: none;">
                            <div class="calender-title" style="
                                {% if calender_note.date.getYoubi() == '土' %}
                                    color: blue;
                                {% elseif calender_note.date.getYoubi() == '日' %}
                                    color: red;
                                {% endif %}
                                {% if calender_note.date.getDateString() == 'now'|date('Y-n-j') %}
                                    background-color: yellow;
                                    border-radius: 5px;
                                {% endif %}
                            ">
                                {{ calender_note.date.format('d') }}
                            </div>
                        </a>
                        <div class="overflow-hidden" style="white-space: nowrap; text-overflow: ellipsis;">{{ calender_note.title | raw }}</div>
                    </div>
                    <div class="note-content js-calender-note-content" unit-date="{{ calender_note.date.getDateString() }}">
                        {% for note in calender_note.notes %}
                            {% if thisTag.displayType == 'image' %}
                            {{ note.textHtml | raw }}
                            {% else %}
                            <div style="white-space: nowrap; text-overflow: ellipsis;">
                                {% set fontColor = note.tags[0].displayColor %}
                                <a type="button" class="btn-show-note-view" note_id="{{ note.id }}" style="text-decoration: none; color: {{ fontColor }};">
                                    ・{{ note.titleWithoutDate }}
                                </a>
                            </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                    <div style="height: 15px;">
                        📝
                    </div>
                </div>
            </div>
        {% endfor %}
        </div>
        <div id="note-view">
            <div class="note-view-content">
                <div class="note-view-header">
                    <div id="note-view-title-date"></div>
                    <div id="note-view-title"></div>
                    <div id="note-view-tags"></div>
                </div>
                <div id="note-view-body">
                    <div id="note-text"></div>
                    <div id="note-edit-area" style="display: none;">
                        <textarea id="note-text-for-edit" class="form-control" style="field-sizing: content; font-size:0.8rem;"></textarea>
                        <div class="mt-1 d-flex justify-content-end gap-2">
                            <button id="close-edit-note-btn" class="btn btn-sm btn-outline-secondary" type="button">閉じる</button>
                            <button id="update-edit-note-btn" class="btn btn-sm btn-outline-primary" type="button">更新</button>
                        </div>
                    </div>
                </div>
                <div id="note-view-footer">
                </div>
            </div>
        </div>
    </div>
    {% if(thisTag) %}
    <div class="mb-5 p-3">
        <div class="text-dark">＜ {{ thisTag.name }} ＞ <a href="{{ path('edit_note_tags', { id: thisTag.id }) }}">編集</a></div>
        <div class="mt-1">{{ thisTag.description | raw }}</div>
        <div class="mt-1">{{ thisTag.textHtml | raw }}</div>
    </div>
    <div>
        <a class="btn btn-outline-warning btn-sm" href="{{ path('app_unitary', { tagName: thisTag.name, mode: '' }) }}">
            << 一覧形式で表示
        </a>
        <a class="btn btn-outline-warning btn-sm" href="{{ path('app_unitary', { tagName: thisTag.name, mode: 'card' }) }}">
            >> カード形式で表示
        </a>
    </div>
    {% endif %}
    <script>
        initShowNoteViewButtons = function() {
            const buttons = document.querySelectorAll(".btn-show-note-view");
            buttons.forEach(btn => {
                btn.addEventListener("click", function() {
                    const noteId = this.getAttribute("note_id");
                    if(!noteId) return;
                    const url = "{{ path('api_get_one_unitary', { noteId: 'NOTE_ID' }) }}".replace("NOTE_ID", noteId);
                    fetch(url, {
                        method: 'GET'
                    }).then(response => response.json())
                    .then(data => {
                        document.getElementById("note-view").setAttribute("note-id", noteId);
                        const height = document.querySelector(".calender-cards-box").offsetHeight;
                        document.getElementById("note-view").style.height = height + "px";
                        document.getElementById("note-view").style.overflowY = "scroll";
                        document.getElementById("note-view-title-date").innerText = data.note.titleDate;
                        document.getElementById("note-view-title").innerText = data.note.titleWithoutDate;
                        document.getElementById("note-view-tags").innerHTML = data.note.tags.map(tag => `<span>#${tag.name}</span>`).join(' ');
                        document.getElementById("note-text").innerHTML = data.note.textHtml;
                        document.getElementById("note-text-for-edit").value = data.note.text;
                        console.log(data);
                    });
                });
            });
        }

        const updateBtn = document.getElementById("update-edit-note-btn");
        const closeBtn = document.getElementById("close-edit-note-btn");
        const noteEditArea = document.getElementById("note-edit-area");
        const noteText = document.getElementById("note-text");
        const noteTextForEdit = document.getElementById("note-text-for-edit");

        resetEditNoteArea = function() {
            noteEditArea.style.display = "none";
            noteText.style.display = "block";
        }

        initEditNoteButtons = function() {
            noteText.addEventListener("click", async function() {
                noteEditArea.style.display = "block";
                noteText.style.display = "none";
            });

            closeBtn.addEventListener("click", async function() {
                noteEditArea.style.display = "none";
                noteText.style.display = "block";
            });

            updateBtn.addEventListener("click", async function() {
                const noteId = document.getElementById("note-view").getAttribute("note-id");
                if(!noteId) return;

                const payload = { text: noteTextForEdit.value };

                try {
                    let url = `${Routing.generate('api_edit_unitary', { noteId: noteId })}`;
                    const res = await fetch(url, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(payload)
                    });

                    if (!res.ok) throw new Error(`${res.status} ${res.statusText}`);
                    const data = await res.json();

                    noteText.innerHTML = data.note.textHtml;
                    noteEditArea.style.display = "none";
                    noteText.style.display = "block";

                } catch (err) {
                    console.error('送信エラー', err);
                    alert('送信失敗: ' + err.message);
                }
            });
        }

        window.addEventListener("load", () => {
            initShowNoteViewButtons();
            initEditNoteButtons();
        });
    </script>
{% endblock %}

{% block style %}
    .calender-title {
        font-size:0.8rem;
        font-weight:bold;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
        color: #003399;
        text-decoration: none;
    }
    .calender-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 6px;
    }
    .calender-normal-view {
        overflow-y: scroll;
        overflow-x: hidden;
    }
    .calender-normal-view > div {
        margin-bottom: 20px;
    }
    .calender-normal-view .unitary-title .text-dark {
        font-size: 0.9rem;
        font-weight: bold;
    }
    .calender-toggle-btn {
        padding: 2px 6px;
        font-size: 0.65rem;
        line-height: 1.1;
    }
    .calender-tags {
        text-decoration: none;
    }
    .calender-box-header {
        width: 1100px;
    }
    .calender-cards-box {
        display: flex;
        flex-wrap: wrap;
        align-items: stretch;
        width: 1100px;
        margin: 10px auto;
    }
    .calender-card {
        width: 14.2%;
        padding: 1px;
        border: 0.5px solid #8eb0d1;
    }
    .calender-card.youbi {
        display: flex;
        justify-content: center;
    }
    .note-card {
        height: 100%;
        font-size:0.7rem;
        padding: 5px;
        color: #003399;
    }
    .note-content {
        height: 90px;
        overflow: hidden;
    }
    @media screen and (max-width: 480px) {
        /* 480px以下に適用されるCSS（スマホ用） */
        .calender-card {
            width: 95%;
        }
    }
    #note-view {
        width: 350px;
        padding-right: 15px;
        padding-bottom: 15px;
    }
    #note-view-title {
        font-size: 1.2rem;
        font-weight: bold;
    }
    .note-view-header {
        margin-bottom: 20px;
    }
    #note-view-tags span {
        font-size: 0.6rem;
        color: blue;
    }
{% endblock %}
